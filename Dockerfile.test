FROM docker.m.daocloud.io/library/node:22-slim

RUN npm install -g pnpm@10 && \
    apt-get update && apt-get install -y python3 python3-venv git build-essential python3-dev && \
    apt-get clean

WORKDIR /app
COPY . .

ENV CI=true
RUN pnpm install && pnpm -r --filter '!mcp-opennutrition' --filter '!knowledge-assistant' run build
# opennutrition requires native deps, build separately (may fail in minimal containers)
RUN cd packages/mcp-opennutrition && npm install && npm run build 2>/dev/null || echo "opennutrition build skipped (native deps)"

# Test non-interactive install with defaults (no config, no secrets)
RUN node packages/adapters/claude-code/dist/install.js install --non-interactive

# Verify installation artifacts
RUN echo "=== Config ===" && \
    cat ~/.knowledge-assistant/config.yaml 2>/dev/null || echo "(using defaults)" && \
    echo "=== KB dir ===" && \
    ls ~/knowledge-base/ && \
    echo "=== Skills ===" && \
    ls ~/.claude/skills/ && \
    echo "=== Hooks ===" && \
    cat ~/.claude/settings.json | python3 -c "import sys,json; [print(k) for k in json.load(sys.stdin).get('hooks',{})]" && \
    echo "=== MCP ===" && \
    cat ~/.claude.json | python3 -c "import sys,json; [print(k) for k in json.load(sys.stdin).get('mcpServers',{})]" && \
    echo "=== CLAUDE.md ===" && \
    head -5 ~/.claude/CLAUDE.md && \
    echo "=== Tests ===" && \
    pnpm test 2>&1 | grep -E "Tests|passed|failed"

CMD ["echo", "All checks passed"]
