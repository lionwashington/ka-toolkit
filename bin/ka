#!/bin/bash
# ka — Knowledge Assistant CLI.
#   ka workshop [start|stop|restart|spawn-mates] [name]   tmux panes / CCs
#   ka daemon   [start|stop|restart|status|config]        the active channel daemon
#   ka status | doctor | cron … | distill [status] | help
#
# Symlink into PATH:
#   ln -sf "$PWD/bin/ka" ~/.local/bin/ka

set -euo pipefail

# Resolve repo root even when invoked via symlink.
_src="${BASH_SOURCE[0]}"
while [ -L "$_src" ]; do
    _dir="$(cd -P "$(dirname "$_src")" && pwd)"
    _src="$(readlink "$_src")"
    [[ "$_src" != /* ]] && _src="$_dir/$_src"
done
BIN_DIR="$(cd -P "$(dirname "$_src")" && pwd)"
REPO_ROOT="$(cd "$BIN_DIR/.." && pwd)"
CLI_DIR="$REPO_ROOT/ops/cli"
export KA_REPO_ROOT="$REPO_ROOT"

CMD="${1:-help}"
[ $# -gt 0 ] && shift || true

case "$CMD" in
    status|doctor|cron|workshop|daemon)
        # workshop = tmux panes / CCs (no daemon ops); daemon = the active channel daemon.
        exec "$CLI_DIR/${CMD}.sh" "$@"
        ;;
    distill)
        # Background distill is the only mode (synchronous distill lives inside
        # /kb distill --foreground). `ka distill status` shows the last run.
        if [ "${1:-}" = "status" ]; then
            shift
            exec "$REPO_ROOT/ops/kb/distill-status.sh" "$@"
        fi
        # Tolerate a legacy --background flag (background is the default now).
        FILTERED=()
        for arg in "$@"; do [ "$arg" = "--background" ] && continue; FILTERED+=("$arg"); done
        exec "$REPO_ROOT/ops/kb/distill-bg.sh" ${FILTERED[@]+"${FILTERED[@]}"}
        ;;
    -h|--help|help|'')
        exec "$CLI_DIR/help.sh" "$@"
        ;;
    *)
        echo "ka: unknown command '$CMD' (try 'ka help')" >&2
        exit 2
        ;;
esac
