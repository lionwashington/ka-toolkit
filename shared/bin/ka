#!/bin/bash
# ka — Knowledge Assistant CLI.
#   ka workshop [start|stop|restart|spawn-mates] [name]   tmux panes / CCs
#   ka workshop peek <name> [lines] | poke <name> <keys…>  inspect/unstick a pane (out-of-band)
#   ka daemon   [start|stop|restart|status|config]        the active channel daemon
#   ka kb retrieval [start|stop|restart|status]            shared LanceDB retrieval daemon
#   ka kb reindex [--full]                                 (re)build the kb_search index
#   ka kb distill [status]                                 background distillation
#   ka status | doctor | cron … | help
#
# Symlink into PATH:
#   ln -sf "$PWD/shared/bin/ka" ~/.local/bin/ka

set -euo pipefail

# The ka tree has a single root: KA_HOME (env var, default ~/.knowledge-assistant).
# bin/ka does NOT derive the root from its own location — it reads KA_HOME the same
# way every other script (and the runtime) does, then loads the directory map and
# dispatches each verb to its part. To run a checkout instead of the deployed
# system, point KA_HOME at it.
: "${KA_HOME:=$HOME/.knowledge-assistant}"
export KA_HOME
# shellcheck source=../ops/common.sh
source "$KA_HOME/shared/ops/common.sh"

CMD="${1:-help}"
[ $# -gt 0 ] && shift || true

case "$CMD" in
    status|doctor)
        exec "$KA_SHARED_DIR/${CMD}.sh" "$@"
        ;;
    workshop)        # tmux panes / CCs (no daemon ops)
        exec "$KA_WORKSHOP_DIR/workshop.sh" "$@"
        ;;
    daemon)          # the active channel daemon
        exec "$KA_CHANNELS_DIR/daemon.sh" "$@"
        ;;
    kb)              # knowledge-base ops cluster: kb retrieval … | kb reindex …
        exec "$KA_KB_DIR/kb.sh" "$@"
        ;;
    cron)
        exec "$KA_CRON_OPS_DIR/cron.sh" "$@"
        ;;
    -h|--help|help|'')
        exec "$KA_SHARED_DIR/help.sh" "$@"
        ;;
    *)
        echo "ka: unknown command '$CMD' (try 'ka help')" >&2
        exit 2
        ;;
esac
